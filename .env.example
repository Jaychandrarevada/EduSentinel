# ─────────────────────────────────────────────────────────────
#  EduSentinel – Environment Variable Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in ALL values marked <CHANGE_ME>
#  3. NEVER commit .env to version control — it's in .gitignore
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
APP_ENV=production            # development | staging | production
DEBUG=false                   # set true only in development
APP_VERSION=1.0.0

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_HOST=postgres              # Docker service name; use actual host in cloud
DB_PORT=5432
DB_NAME=edusentinel
DB_USER=edu_user
DB_PASSWORD=<CHANGE_ME>       # strong password, no special chars in URL
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis              # Docker service name
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME>   # required in production
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ── Security / JWT ────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<CHANGE_ME>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60     # 1 hour
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML Service ────────────────────────────────────────────────
ML_SERVICE_URL=http://ml_service:8001  # internal Docker network name
ML_MODEL_STORE_PATH=/app/artifacts
ML_MIN_DATA_WEEKS=3                    # min weeks of data before predictions run

# ── Frontend ──────────────────────────────────────────────────
# In production set this to your public API URL, e.g.:
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=EduSentinel

# ── CORS ──────────────────────────────────────────────────────
# JSON array of allowed origins — must match your deployed frontend URL
CORS_ORIGINS=["http://localhost:3001","http://localhost:3000"]
# Production example:
# CORS_ORIGINS=["https://app.yourdomain.com"]

# ── Email / SMTP (at-risk notifications) ─────────────────────
NOTIFICATION_ENABLED=false    # set true to send emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<CHANGE_ME>
SMTP_PASSWORD=<CHANGE_ME>     # Gmail: use App Password, not account password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=EduSentinel

# ── Object Storage (model artifacts — optional) ───────────────
# Leave blank to use local filesystem storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=edusentinel-artifacts

# ── Deployment platform variables ────────────────────────────
# Render / Railway: set these in the platform's environment settings
# PORT is automatically set by most platforms — don't change it here
