# ──────────────────────────────────────────────────────────────────────────────
#  EduSentinel Backend — Environment Variable Template
#
#  Copy to .env and fill in the values:
#    cp .env.template .env
#
#  NEVER commit the filled .env file to version control.
#  For production (Render.com), set these in the Render dashboard or render.yaml.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_NAME=EduSentinel API
APP_VERSION=1.0.0
DEBUG=true                   # set to false in production

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL:
DATABASE_URL=postgresql+asyncpg://edu_user:password@localhost:5432/edusentinel
# Render (auto-set via render.yaml fromDatabase):
# DATABASE_URL=postgresql+asyncpg://edu_user:...@dpg-xxx.render.com/edusentinel

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array format)
# Local dev:
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
# Production:
# CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# ── ML Service ────────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8001     # URL of the ML microservice
ML_REQUEST_TIMEOUT=120                   # seconds to wait for ML predictions

# ── Redis (for Celery task queue — optional for basic deployment) ─────────────
REDIS_URL=redis://localhost:6379/0

# ── Email / Notifications ─────────────────────────────────────────────────────
# Set NOTIFICATION_ENABLED=true to enable email alerts for at-risk students.
NOTIFICATION_ENABLED=false

# Gmail SMTP example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASSWORD=your-app-password   (use Gmail App Password, not your main password)

# SendGrid SMTP example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=SG.your-sendgrid-api-key

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@edusentinel.dev
